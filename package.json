{
  "name": "plaet-api",
  "version": "1.1.0",
  "description": "Plaet API para administración y contabilidad de restaurantes. ",
  "main": "src/server.ts",
  "scripts": {
    "start": "npx prisma migrate deploy && node dist/server.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec ts-node src/server.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:integration": "TEST_TYPE=integration jest",
    "test:e2e": "TEST_TYPE=e2e jest",
    "test:all": "npm test && TEST_TYPE=integration npm test && TEST_TYPE=e2e npm test",
    "test:db:start": "bash scripts/test-db-setup.sh start",
    "test:db:stop": "bash scripts/test-db-setup.sh stop",
    "test:db:reset": "bash scripts/test-db-setup.sh reset",
    "test:db:migrate": "bash scripts/test-db-setup.sh migrate",
    "test:db:status": "bash scripts/test-db-setup.sh status",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate || true",
    "eslint-check-only": "npx eslint .",
    "eslint-fix": "npx eslint . --fix",
    "prettier": "npx prettier --write ."
  },
  "keywords": [
    "api",
    "plaet",
    "backend",
    "management",
    "restaurant"
  ],
  "author": "NgCraftz",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcrypt": "^5.1.1",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "resend": "^6.9.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/moment-timezone": "^0.5.13",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.15",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
